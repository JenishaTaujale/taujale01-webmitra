rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validation Helper
    function isValidStoreConfig(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 150
        && data.slug is string && data.slug.size() <= 150
        && data.tagline is string && data.tagline.size() <= 300
        && data.description is string && data.description.size() <= 1500
        && data.category is string && data.category.size() <= 150
        && data.accentColor is string && data.accentColor.size() <= 50
        && data.products is list;
    }

    // Match block for store configurations
    match /storeConfigs/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId)
        && isValidStoreConfig(incoming())
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(userId)
        && isValidStoreConfig(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }
}
